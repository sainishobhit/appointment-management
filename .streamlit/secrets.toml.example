# Copy this file to `.streamlit/secrets.toml` and fill in real values.
# `.streamlit/secrets.toml` is gitignored and must NEVER be committed.
#
# LOCAL DEV: you can leave `db_url` unset — the app falls back to a local
# SQLite file (dentaflow.db). `app_password` also defaults to "dentist" locally.
#
# PRODUCTION (Streamlit Community Cloud): set both in the app's Secrets UI.

# Managed Postgres connection string from Neon or Supabase (free tier).
# Note the `+psycopg` driver and sslmode=require.
db_url = "postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Password required to open the app (dentist only).
app_password = "change-me-to-something-strong"
